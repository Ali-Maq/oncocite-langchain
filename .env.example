# Fireworks AI API key (required)
FIREWORKS_API_KEY=

# Model selection (optional — defaults shown)
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL_NAME=accounts/fireworks/models/glm-4p7
FIREWORKS_VISION_MODEL=accounts/fireworks/models/qwen3-vl-235b-a22b-thinking

# Runtime tuning (optional)
MAX_ITERATIONS=4
MAX_TURNS=50
CHUNK_SIZE=1
DEFAULT_MAX_TOKENS=4096
DEFAULT_TEMPERATURE=0.0
API_TIMEOUT=15
VERBOSE=true

# Reader rendering (optional)
READER_RENDER_MODE=tiled
TILE_ROWS=2
TILE_COLS=3
TILE_OVERLAP=0.08
TILE_DPI=300
READER_CONCURRENCY=4

# LangGraph
LANGGRAPH_CHECKPOINT_BACKEND=sqlite
